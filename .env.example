# Avatar Agent local environment names only. Copy to `.env` for local development.
# Real values must stay in local/host secret storage and must never be committed.

## Avatar providers
ANAM_API_KEY=
ANAM_AVATAR_ID=
AVATAR_PERSONA_NAME=Jami Studio
AVATAR_PERSONA_KEYS=MEGAN,SARAH,ALEXIS
MEGAN=
SARAH=
ALEXIS=
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
ELEVENLABS_VOICE_ID=
AVATAR_AGENT_PRESETS=

# Upstream account alias accepted by the runtime when projecting from ../oss/.env:
# ELEVEN_LABS_API_KEY -> ELEVENLABS_API_KEY

## Product inference / computer-use candidates
GOOGLE_GENERATIVE_AI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=

## Observability and product analytics
OTEL_SERVICE_NAME=avatar-agent
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=avatar-agent
POSTHOG_API_KEY=
POSTHOG_HOST=
AMPLITUDE_API_KEY=

# Upstream account alias accepted by the runtime when projecting from ../oss/.env:
# POSTHOG_KEY -> POSTHOG_API_KEY

## Deployment
PUBLIC_APP_URL=
